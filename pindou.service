[Unit]
Description=PinDou Bead Pattern Generator
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/pindou
ExecStart=/opt/pindou/venv/bin/gunicorn -c gunicorn_config.py app:app
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
